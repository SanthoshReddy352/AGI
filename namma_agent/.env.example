# Namma Agent (cloud-only) — environment template.
#
#   cp namma_agent/.env.example .env       # the repo loads ".env" from the project root
#
# Only the API key for the provider you use is required. Everything else is
# optional and the matching feature simply stays off if unset.
# Shell environment variables take precedence over .env at runtime.

# ── Provider API keys (set the one matching config.yaml provider.type) ──
# Anthropic (default). Get a key: https://console.anthropic.com/
ANTHROPIC_API_KEY=

# OpenAI (or any OpenAI-compatible endpoint). https://platform.openai.com/
OPENAI_API_KEY=

# Google Gemini. https://aistudio.google.com/apikey
GOOGLE_API_KEY=

# Generic key name for a custom openai_compat endpoint (base_url in config.yaml).
NAMMA_API_KEY=

# ── Messaging channels (optional — comms tools + Telegram bridge) ──
# Telegram: create a bot via @BotFather, message it once to get your chat id.
# With both set, Namma Agent sends notifications AND you can chat with it from your phone.
NAMMA_TELEGRAM_TOKEN=
NAMMA_TELEGRAM_CHAT_ID=
# Discord: channel settings → Integrations → Webhooks → New Webhook → copy URL.
NAMMA_DISCORD_WEBHOOK_URL=

# ── Smart home (optional — Home Assistant tools) ───────────────────
# Long-lived access token; the var name must match smart_home.token_env in config.yaml.
HASS_TOKEN=

# ── Notes ──────────────────────────────────────────────────────────
# • Local providers (Ollama / LM Studio) need NO key — set provider.type
#   accordingly in namma_agent/config.yaml and leave the keys blank.
# • Security tools (port_scan etc.) are OFF until you set security.lab_mode: true
#   and security.authorized_scopes in namma_agent/config.yaml — no env var involved.
