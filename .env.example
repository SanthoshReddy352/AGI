# FRIDAY — environment template.
#
# Copy this file to ".env" (the setup scripts do this automatically) and fill
# in the values you need. ".env" is git-ignored, so your keys never get
# committed. Shell environment variables take precedence over .env at runtime.
#
#   cp .env.example .env       # Linux/macOS
#   Copy-Item .env.example .env  # Windows PowerShell
#
# Everything here is OPTIONAL except where noted — FRIDAY boots without any of
# these and simply disables the corresponding feature.

# ===========================================================================
# Wake word — "Hey Friday"  (Porcupine)
# ===========================================================================
# Required to use the wake word (hands-free launch / re-wake). Without it,
# FRIDAY still works via manual listening and the text CLI.
# Get a free access key at: https://console.picovoice.ai/
FRIDAY_PORCUPINE_KEY=

# Optional: built-in wake phrase used on platforms where no custom "Hey Friday"
# .ppn is bundled (e.g. Windows/macOS). Any Porcupine built-in keyword works:
# jarvis, computer, alexa, "hey google", "ok google", bumblebee, terminator...
# FRIDAY_WAKE_KEYWORD=jarvis

# Optional: pin a specific microphone for the wake-word listener by index.
# Default (-1) uses the system default input device.
# FRIDAY_WAKE_MIC_INDEX=-1

# ===========================================================================
# Messaging integrations
# ===========================================================================
# Telegram bot bridge (send/receive messages). Create a bot via @BotFather.
FRIDAY_TELEGRAM_TOKEN=
FRIDAY_TELEGRAM_CHAT_ID=

# Discord notifications via an incoming webhook URL.
# FRIDAY_DISCORD_WEBHOOK_URL=

# ===========================================================================
# External data / research APIs
# ===========================================================================
# Feed Prism / World Monitor feed API key (news + world-state features).
FEED_PRISM_API_KEY=

# Optional self-hosted SearXNG instances for web search (comma-separated).
# FRIDAY_SEARXNG_INSTANCES=https://searx.example.org

# ===========================================================================
# Cloud LLM fallback (optional — FRIDAY is local-first)
# ===========================================================================
# Only used if you explicitly enable a cloud provider for fallback chat.
# ANTHROPIC_API_KEY=
# OPENAI_API_KEY=

# ===========================================================================
# Routing / model behaviour toggles
# ===========================================================================
# Enable the Gemma 2B shadow router (requires models/gemma-2b-it.gguf).
# FRIDAY_USE_GEMMA_ROUTER=1

# TTS playback backend: auto (default) | pw-cat | aplay  (Linux only knobs;
# Windows always uses the built-in sounddevice backend).
# FRIDAY_TTS_BACKEND=auto

# ===========================================================================
# Setup-time model source overrides (used by setup.sh / setup.ps1)
# ===========================================================================
# If you host the GGUF models yourself, point the installers at them here
# instead of editing the scripts. Leave blank to place files in models/ by hand.
# FRIDAY_CHAT_MODEL_URL=
# FRIDAY_TOOL_MODEL_URL=
# FRIDAY_GEMMA_MODEL_URL=

# ===========================================================================
# Advanced / rarely needed
# ===========================================================================
# Force the Hugging Face stack online even when a local cache exists.
# FRIDAY_HF_ONLINE=1
# Skip main.py's automatic re-exec under .venv (when running under another venv).
# FRIDAY_SKIP_VENV_AUTOEXEC=1
